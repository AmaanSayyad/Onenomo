# CreditCoin Testnet Configuration
# RPC endpoint for CreditCoin testnet blockchain
NEXT_PUBLIC_CREDITCOIN_TESTNET_RPC=https://rpc.cc3-testnet.creditcoin.network

# Chain ID for CreditCoin testnet (102031)
NEXT_PUBLIC_CREDITCOIN_TESTNET_CHAIN_ID=102031

# Block explorer URL for CreditCoin testnet
NEXT_PUBLIC_CREDITCOIN_TESTNET_EXPLORER=https://creditcoin-testnet.blockscout.com

# CreditCoin native currency symbol
NEXT_PUBLIC_CREDITCOIN_TESTNET_CURRENCY=CTC

# CreditCoin currency symbol for display
NEXT_PUBLIC_CREDITCOIN_TESTNET_CURRENCY_SYMBOL=CTC

# CreditCoin native token decimals (18)
NEXT_PUBLIC_CREDITCOIN_TESTNET_CURRENCY_DECIMALS=18

# CreditCoin Treasury Configuration
# Treasury wallet address for deposits (public)
CREDITCOIN_TREASURY_ADDRESS=0x71197e7a1CA5A2cb2AD82432B924F69B1E3dB123

# Treasury private key for withdrawals (KEEP SECRET - server-side only)
CREDITCOIN_TREASURY_PRIVATE_KEY=your_treasury_private_key_here

# Public treasury address for client-side display
NEXT_PUBLIC_CREDITCOIN_TREASURY_ADDRESS=0x71197e7a1CA5A2cb2AD82432B924F69B1E3dB123

# Supabase Configuration
# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url

# Supabase anonymous key (public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Wallet Connection Configuration
# WalletConnect project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Privy Configuration (optional - for social login)
# Privy app ID (public)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# Privy app secret (KEEP SECRET - server-side only)
PRIVY_APP_SECRET=your_privy_app_secret

# Application Configuration
# Application name displayed in UI
NEXT_PUBLIC_APP_NAME=CreditNomo

# Network mode (testnet or mainnet)
NEXT_PUBLIC_CTC_NETWORK=testnet

# Game Configuration
# Default round duration in seconds
NEXT_PUBLIC_ROUND_DURATION=30

# Price update interval in milliseconds
NEXT_PUBLIC_PRICE_UPDATE_INTERVAL=1000

# Chart time window in milliseconds
NEXT_PUBLIC_CHART_TIME_WINDOW=300000
